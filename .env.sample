# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าก่อนใช้งาน
# cp .env.sample .env

# ---- Django Core ----
SECRET_KEY=REPLACE_WITH_GENERATED_KEY
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,110.78.83.102,lib.npu.ac.th

# ---- Path-based Routing (IIS ARR) ----
FORCE_SCRIPT_NAME=/reserv
STATIC_URL=/reserv/static/

# ---- CSRF ----
CSRF_TRUSTED_ORIGINS=https://lib.npu.ac.th

# ---- Waitress ----
WAITRESS_HOST=127.0.0.1
WAITRESS_PORT=8003
WAITRESS_THREADS=8

# ---- Database (MySQL) ----
DB_NAME=reserv_db
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=your_db_host
DB_PORT=3306

# ---- LINE LIFF ----
LINE_CHANNEL_SECRET=your_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token
LINE_LIFF_ID=your_liff_id

# ---- Phase 2: IoT ----
HA_ACCESS_SECRET=your_random_secret
